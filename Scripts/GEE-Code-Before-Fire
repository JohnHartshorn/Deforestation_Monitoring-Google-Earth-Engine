// Define visualization parameters. You may define different parameters for each year if the sensors have different bands


var L5viz = { bands: ['B6', 'B5', 'B4'], min:5979,max:18330 };
var L8viz = {
    bands: ['B6', 'B5', 'B4'],
    min: 5135,
    max: 10240, //you can play around with these numbers and see how they change the colors of the display
};

Map.addLayer(BeforeFire, L5viz, 'BeforeFireChange',false);
Map.addLayer(PostFire, L8viz, 'PostFireChange',false);



// select bands 1-5 and 7, and rename to append year

var BeforeFire = BeforeFire.select(['B1', 'B2', 'B3', 'B4','B5', 'B7'])
.rename(['Blue_Before', 'Green_Before', 'Red_Before', 'NIR_Before','SWIR1_Before', 'SWIR2_Before']);

// select bands 2-7 of Landsat 8, and rename to append year


var PostFire = PostFire.select(['B2', 'B3', 'B4', 'B5', 'B6', 'B7'])
.rename(['Blue_Post', 'Green_Post', 'Red_Post', 'NIR_Post','SWIR1_Post', 'SWIR2_Post']);

var forestchange = PostFire.addBands(BeforeFire);
print('forestchange',forestchange); //verify your results in the console
Map.addLayer(forestchange.select('Red_Post'),{},'Red band',false);




Map.addLayer(forestchange, {bands: ['Red_Post', 'Red_Before','Red_Post'], min:6525, max:8637,gamma: 1}, 'forestchange', false);






