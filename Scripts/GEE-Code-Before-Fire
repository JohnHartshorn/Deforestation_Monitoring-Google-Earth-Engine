/***** End of imports. If edited, may not auto-convert in the playground. *****/
/// Center the map over the location of the Caldera Fire
Map.setCenter(-120.3, 38.7000, 10);

///Define region of interest
var CaldorFire = ee.Geometry.Polygon(
        [[[-120.64675598144531, 38.95622510781989],
          [-120.62341003417968, 38.42133838578212],
          [-119.80080871582031, 38.429945244340935],
          [-119.89144592285156, 38.97330956860997]]]);
          

//
//
//
//
//
//Import Landsat Image for 08/05/2021
//Before the fire
//
//
//
//
//

var BeforeFire = ee.Image('LANDSAT/LC08/C02/T1/LC08_043033_20210805')
    .select("B1","B2","B3","B4","B5","B6","B7");
    

/////Select bands to be used
var bands = ['B1', 'B2', 'B3', 'B4', 'B5', 'B6'];

print("Before Fire image", BeforeFire);

/////subset Before fire to area of interest
var BeforeFire = BeforeFire.clip(CaldorFire);

  
/////display a color composite of Landsat 7 bands 543, stretched between DN 0 and 200 to improve the visualization
Map.addLayer(BeforeFire, {bands: ['B4', 'B3', 'B2'], min: 6385, max: 12470}, "Before Fire"); 


var PostFire = ee.Image('LANDSAT/LC09/C02/T1/LC09_043033_20211121')
    .select("B1","B2","B3","B4","B5", "B6", "B7");


/////Select bands to be used
var bands = ['B1', 'B2', 'B3', 'B4', 'B5', 'B6'];


print("Post Fire image", PostFire);

//subset PostFire to area of interest
var PostFire = PostFire.clip(CaldorFire);

  
//display a color composite of Landsat 8 bands 543, stretched between DN 0 and 200 to improve the visualization
Map.addLayer(PostFire, {bands: ['B4', 'B3', 'B2'], min: 4809, max: 9219}, "Post Fire", false); 

    


///
///
///
///

//Supervsed classifications for BF

///
///
///

// Make the training dataset by randomly sampling 1000 pixels from the image
var training = BeforeFire.sample({
  region: CaldorFire,
  scale: 30,
  numPixels: 1000
});
//Print and study the variable training:
print("trainingBeforeFire",training);


// Instantiate the clusterer and train it.
var clustererBeforeFire = ee.Clusterer.wekaKMeans(10).train(training);


// Cluster the input using the trained clusterer.
var clusteredBeforeFire = BeforeFire.cluster(clustererBeforeFire);
print('clusteredBeforeFire',clusteredBeforeFire);



// Display the clusters with a custom palette
Map.addLayer(clusteredBeforeFire, {palette: ['red', 'DFDBC2', '53B00C','1c9099', '0244BE', '60423F','1c9099', '35432A', '35432A', 'ece2f0'], min:1, max:10}, 'clustered',false);





//
//
//
//Classified for BF
//merge feature collections
//
//
//


var sampleBeforeFireFC = Water.merge(Urban).merge(Forest).merge(CutForest).merge(BareSoil).merge(BurnScars);
var trainingBeforeFireFC = sampleBeforeFireFC;

// Add a column of random numbers to split the training points by 70%/30% 
var sampleBeforeFireFC=sampleBeforeFireFC.randomColumn();


var split = 0.7;  // Split the sample 70% training, 30% testing.
var trainingBeforeFireFC = sampleBeforeFireFC.filter(ee.Filter.lt('random', split));
print(trainingBeforeFireFC,'Training points for classifierBeforeFireFC');   //points for classifier answer: 569 elements, 1 column
var validationBeforeFireFC = sampleBeforeFireFC.filter(ee.Filter.gte('random', split));
print(validationBeforeFireFC,'Validation pointsBeforeFireFC');     


// Get the values for all pixels in each polygon in the training.
var trainingBeforeFire = BeforeFire.select(bands).sampleRegions({
  // Get the sample from the polygons FeatureCollection.
  collection: trainingBeforeFireFC,
  // Keep this list of properties from the polygons.
  properties: ['class'],
  // Set the scale to get Landsat pixels in the polygons.
  scale: 30
});
print('trainingBeforeFire', trainingBeforeFire);


//  Train a minimum distance classifier
var MDclassifier = ee.Classifier.minimumDistance("euclidean").train({
features: trainingBeforeFire, 
  classProperty: 'class', 
  inputProperties: bands
});

// Classify the input imagery.
var MDclassified = BeforeFire.select(bands).classify(MDclassifier);

// Display the clusters with random colors. The first three bands of the output image will contain 8-bit R, G and B values, 
// followed by the band of the clustered image.
Map.addLayer(MDclassified.randomVisualizer(), {}, 'MD clustersBeforeFire', false);



/* Train a random forest classifier
 A random forest classifier uses a combination of
decision tree classifiers where each is generated using a random vector sampled independently
from the input vector. Each tree casts a unit vote for the most popular class to classify an input
vector . */
var RFclassifier = ee.Classifier.smileRandomForest(100) //set the number of trees in random forest to 100
.train(trainingBeforeFire, 'class', bands); 

// Classify the input imagery with the Random Forest classifier
var RFclassified = BeforeFire.select(bands).classify(RFclassifier);


// Display the clusters with random colors. The first three bands of the output image will contain 8-bit R, G and B values, 
// followed by the band of the clustered image.
Map.addLayer(RFclassified.randomVisualizer(), {}, 'RF clustersBeforeFire', false);

//
//
//
//

// Get the values for all pixels in each polygon in the validation.
var MDvalidation = MDclassified.sampleRegions({
  // Get the sample from the polygons FeatureCollection.
  collection: validationBeforeFireFC,
  // Keep this list of properties from the polygons.
  properties: ['class'],
  // Set the scale to get Landsat pixels in the polygons.
  scale: 30
});
print("MDvalidationBeforeFire",MDvalidation);


// Compare the landcover of your validation data against the classification result
var MDvalidationAccuracy = MDvalidation.errorMatrix('class', 'classification');
//Print the error matrix to the console
print('MD Error matrixBeforeFire: ', MDvalidationAccuracy);
//Print the overall accuracy to the console
print('MD Overall accuracyBeforeFire: ', MDvalidationAccuracy.accuracy());
// Print the kappa coefficient
print('MD kappaBeforeFire: ', MDvalidationAccuracy.kappa());
// Print the User's accuracy
print('MD consumersAccuracy()BeforeFire', MDvalidationAccuracy.consumersAccuracy());
// Print the Producer's accuracy
print('MD producersAccuracy()BeforeFire', MDvalidationAccuracy.producersAccuracy());


//Repeat for RandomForest
// Get the values for all pixels in each polygon in the validation.
var RFvalidation = RFclassified.sampleRegions({
  // Get the sample from the polygons FeatureCollection.
  collection: validationBeforeFireFC,
  // Keep this list of properties from the polygons.
  properties: ['class'],
  // Set the scale to get Landsat pixels in the polygons.
  scale: 30
});
print("RFvalidationBeforeFire",RFvalidation);


// Compare the landcover of your validation data against the classification result
var RFvalidationAccuracy = RFvalidation.errorMatrix('class', 'classification');
//Print the error matrix to the console
print('RF Error matrix:BeforeFire ', RFvalidationAccuracy);
//Print the overall accuracy to the console
print('RF Overall accuracy:BeforeFire ', RFvalidationAccuracy.accuracy());
// Print the kappa coefficient
print('RF kappa:BeforeFire ', RFvalidationAccuracy.kappa());
// Print the User's accuracy
print('RF consumersAccuracy()BeforeFire', RFvalidationAccuracy.consumersAccuracy());
// Print the Producer's accuracy
print('RF producersAccuracy()BeforeFire', RFvalidationAccuracy.producersAccuracy());


//Query the map: click on the Inspector tab, on the top of the right window. A cross cursor will allow 
//you to query the map when you click on it. Explore the classes.
//Show only one class, 
//var oneclass = BeforeFire.select("cluster").eq(5).selfMask(); //.selfMask() hides all the pixels that don't match the criterion
//Map.addLayer(oneclass,{},"oneclass");


// Add a white background to the image
// Create an empty image into which to paint white
Map.addLayer(ee.Image(1), {palette:['ffffff']}, 'white',false);  //false indicates that the image will not be loaded by default
// select the image 'white' in the Layers pull down menu



var colortable=['0000FF', '00FF00', '000000', '964B00', '808080', 'FF0000'];
//Replace class 0, 1, 2… with the labels you have identified
var names=['Water', 'Forest', 'BareRock', 'Deforestation', 'BareSoil/Urban'];


Map.addLayer(RFclassified,{palette: colortable, min:1, max:10},"final result RFBeforeFire",false);


Map.addLayer(MDclassified,{palette: colortable, min:1, max:10},"final result MDBeforeFire");

////
////Calculate NBR Image band transformation
////
////
////

////BeforeFire

print('Landsat 8 scene Before Fire, NBR:', BeforeFire);

var swir2 = BeforeFire.select('B7');

var nir = BeforeFire.select('B5');

var nbr_BeforeFire = nir.subtract(swir2).divide(nir.add(swir2));

// Add map layer

Map.addLayer(nbr_BeforeFire, {}, 'NBR pre fire',false);

///
///
///

///PostFire

print('Landsat 9 scene After Fire, NBR:', PostFire);

// recompute nbr with the new landsat 8 scene

var swir2 = PostFire.select('B7');
var nir = PostFire.select('B5');
var nbr_PostFire = nir.subtract(swir2).divide(nir.add(swir2));

// Add map layer

Map.addLayer(nbr_PostFire, {}, 'NBR post fire',false);

///
///
///

// Calculate difference NBR
// recently burned areas will appear brighter and with positive values

var dnbr = nbr_BeforeFire.subtract(nbr_PostFire);

// Add map layer

Map.addLayer(dnbr, {min:-1, max:1}, 'Difference NBR',false);



